# Database
DATABASE_URL=postgresql://dict:dictpass@localhost:5432/dictdb

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Session
# Set a random 32+ char string in production, or leave as 'change-me' to auto-generate from DB
SESSION_SECRET=change-me

# File storage
FILE_STORAGE_LOCAL_PATH=/data/uploads

# Application base URL (used for email verification links)
APP_BASE_URL=http://localhost:3000

# Email (SMTP) — required for registration/verification emails
# If SMTP_HOST is left unset, email sending is skipped and the verification URL is printed to console logs.
# Examples:
#   Gmail:    SMTP_HOST=smtp.gmail.com        SMTP_PORT=587  SMTP_USER=you@gmail.com      SMTP_PASS=<app-password>
#   Outlook:  SMTP_HOST=smtp.office365.com   SMTP_PORT=587  SMTP_USER=you@outlook.com    SMTP_PASS=<app-password>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Set to 'true' for port 465 (SMTPS), 'false' for STARTTLS (port 587)
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="辞书对比平台 <noreply@example.com>"

# Verification token TTL in hours (default: 24)
VERIFICATION_TOKEN_TTL_HOURS=24

# Subscription / Energy system (005-coffee-subscription)
# Energy pre-deduction for scanned PDF uploads (default: 5000 words)
SCANNED_PDF_ENERGY_COST=5000
# Lifetime word-unlock cap for free-tier users (default: 100 words)
FREE_TIER_WORD_CAP=100
