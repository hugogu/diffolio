# Docker image registry prefix (optional)
# Leave empty to use Docker Hub directly.
# For Aliyun VPC registry, set to the registry host + namespace with trailing slash:
#   REGISTRY_PREFIX=crpi-2zi07c2eorm55mbp-vpc.cn-shanghai.personal.cr.aliyuncs.com/hugopub/
REGISTRY_PREFIX=

# Data directory for bind mounts (postgres, redis, uploads)
# Production: set to dedicated data disk path, e.g., /mnt/data/doc-compare
# Development: defaults to ./data (gitignored)
DATA_DIR=./data

# PostgreSQL credentials (used by both the postgres container and DATABASE_URL)
POSTGRES_USER=dict
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=dictdb

# Database connection (must match POSTGRES_* above)
DATABASE_URL=postgresql://dict:change-me-in-production@doc-compare-postgres:5432/dictdb

# Redis
REDIS_URL=redis://redis:6379

# File storage
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=/data/uploads
# FILE_STORAGE_S3_BUCKET=my-bucket
# FILE_STORAGE_S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# App — SESSION_SECRET must be ≥32 chars; leave blank to auto-generate from DB
SESSION_SECRET=
UPLOAD_MAX_SIZE_MB=500
API_PORT=3000
FRONTEND_PORT=5173

# Rate limiting (batch diff API)
DIFF_API_RATE_LIMIT_PER_MINUTE=60

# Prisma transaction timeout (milliseconds)
# Increase if parsing large dictionary files with many entries
PRISMA_TRANSACTION_TIMEOUT_MS=30000

# Email (required for user registration verification and subscription reminders)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_BASE_URL=https://your-domain.com
