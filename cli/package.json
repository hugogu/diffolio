{
  "name": "@diffolio/cli",
  "version": "1.0.0",
  "description": "Diffolio CLI - Dictionary comparison tool for local use",
  "main": "dist/index.js",
  "bin": {
    "diffolio": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "./test.sh",
    "prisma:generate": "prisma generate --schema=../backend/prisma/schema.prisma",
    "prisma:copy": "cp -r ../backend/node_modules/.prisma node_modules/ && cp -r ../backend/node_modules/@prisma/client node_modules/@prisma/"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "exceljs": "^4.4.0",
    "mammoth": "^1.7.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.4",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "dictionary",
    "cli",
    "comparison",
    "diffolio"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hugogu/diffolio.git",
    "directory": "cli"
  }
}
