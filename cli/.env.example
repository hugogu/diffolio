# Diffolio CLI Environment Variables

# Database connection URL
# SQLite (local development):
# DATABASE_URL="file:./data/dictionary.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://user:password@localhost:5432/dictdb"
DATABASE_URL="file:./data/dictionary.db"

# Default format configuration file path
# DIFFOLIO_CONFIG_PATH="./configs/default.json"

# Log level (debug, info, warn, error)
# DIFFOLIO_LOG_LEVEL="info"

# Example usage:
# export DATABASE_URL="file:./data/dictionary.db"
# diffolio parse -f dict.txt -c config.json -n "v1"
